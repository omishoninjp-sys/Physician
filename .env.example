# --- 必要設定 ---
DATABASE_URL=postgres://user:password@localhost:5432/goyoulink_mvp
JWT_SECRET=change-this-to-a-random-secret-in-production
PORT=3000

# --- AI 機能（選填）---
# 設定すれば Claude が利用される（無い場合は demo mode / keyword matching）
ANTHROPIC_API_KEY=

# --- RAG 機能（選填）---
# 設定すれば pgvector + OpenAI embedding で類似検索が有効に（精度向上）
# 無い場合は Claude が context なしで分類
OPENAI_API_KEY=

# --- 環境 ---
NODE_ENV=development
